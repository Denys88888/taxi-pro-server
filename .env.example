# ─── Pi Network ───────────────────────────────────────────────────────────────
# Pi Developer Portal → your app → API Key. NEVER commit the real value.
PI_API_KEY=
# Set to "true" for Pi Testnet (sandbox). "false" for mainnet.
PI_SANDBOX=true

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret, min 32 chars. Generate:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ─── Firebase (optional — server runs in-memory if omitted) ─────────────────────
# Firebase console → Project settings → Service accounts → Generate new private key.
# Keep the private key on one line with literal \n in place of real newlines.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
# Render injects PORT automatically; defaults to 10000 locally.
PORT=10000
# Comma-separated allowed CORS origins (production frontend only; localhost is
# auto-allowed in non-production for local dev).
CORS_ORIGINS=https://denys88888.github.io
# Public URL of this service, used by the 14-min keep-alive self-ping on Render.
RENDER_URL=

# ─── Database ─────────────────────────────────────────────────────────────────
# Primary store is SQLite (WAL). Path to the DB file; defaults to ./data/taxipro.db.
# Set FIREBASE_* above to use Firestore instead (optional cloud DB).
SQLITE_PATH=
