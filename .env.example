# Pi Developer Portal → your app → API Key
PI_API_KEY=

# Session signing secret. Generate:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Firebase service account (Firebase console → Project settings → Service accounts
# → Generate new private key). Use the three values from the downloaded JSON.
# Keep the private key on one line with literal \n in place of newlines.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Public URL of this Render service, used by the 14-min keep-alive self-ping.
# e.g. https://taxi-pro-server.onrender.com
RENDER_URL=

# Render injects PORT automatically; defaults to 10000 locally.
# PORT=10000
